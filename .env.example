# atomno-mcp-fns-check — environment variables (example, без реальных значений)

# === SQLite cache ===
# Путь к файлу SQLite-кэша. По умолчанию — ./atomno_mcp_fns_check_cache.sqlite в CWD.
MCP_FNS_CACHE_DB=./atomno_mcp_fns_check_cache.sqlite

# TTL (Time To Live) для кэша карточек в часах. По умолчанию 168 (7 суток).
MCP_FNS_CACHE_TTL_HOURS=168

# === HTTP client ===
# User-Agent для запросов к egrul.nalog.ru / pb.nalog.ru.
# Согласно SPEC §5.3 — должен содержать контактный email.
MCP_FNS_USER_AGENT=atomno-mcp-fns-check/0.1 (+https://example.com/contact)

# Таймаут одного HTTP-запроса в секундах (по умолчанию 15).
MCP_FNS_HTTP_TIMEOUT=15

# === Логирование ===
# DEBUG / INFO / WARNING / ERROR
MCP_FNS_LOG_LEVEL=INFO
